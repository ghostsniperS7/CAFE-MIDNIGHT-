{
  "entities": {
    "Reservation": {
      "title": "Reservation",
      "description": "A table reservation at Cafe Midnight",
      "type": "object",
      "properties": {
        "fullName": { "type": "string", "description": "Customer's full name" },
        "phone": { "type": "string", "description": "Customer's phone number" },
        "guests": { "type": "integer", "description": "Number of guests" },
        "date": { "type": "string", "description": "Reservation date" },
        "time": { "type": "string", "description": "Reservation time" },
        "notes": { "type": "string", "description": "Special requests or notes" },
        "userId": { "type": "string", "description": "ID of the user who made the reservation" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"], "description": "Status of the reservation" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of creation" }
      },
      "required": ["fullName", "phone", "guests", "date", "time", "userId", "status", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "A food order placed by a customer",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "items": {
          "type": "array",
          "items": { "type": "object" }
        },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "delivering", "delivered", "cancelled"] },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "phone", "items", "total", "status", "userId", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "Customer review for the restaurant",
      "type": "object",
      "properties": {
        "userName": { "type": "string" },
        "userId": { "type": "string" },
        "rating": { "type": "integer", "minimum": 1, "maximum": 5 },
        "comment": { "type": "string" },
        "date": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userName", "userId", "rating", "comment", "date", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "favorites": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["email", "createdAt"]
    }
  },
  "firestore": {
    "reservations/{reservationId}": {
      "schema": "Reservation",
      "description": "Collection of table reservations"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of food orders"
    },
    "reviews/{reviewId}": {
      "schema": "Review",
      "description": "Collection of customer reviews"
    },
    "users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles"
    }
  }
}
